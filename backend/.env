# Flask Configuration
SECRET_KEY=my-super-secret-key-for-development-12345
FLASK_APP=app
FLASK_ENV=development

# Database Configuration  
DATABASE_URL=sqlite:///multimodal_assistant.db

# JWT Configuration
JWT_SECRET_KEY=my-jwt-secret-key-for-development-67890

# CORS Configuration
CORS_ORIGINS=http://localhost:5173

# LLM Provider Configuration (Mock for testing)
LLM_API_KEY=test-api-key
LLM_ENDPOINT=https://api.deepseek.com/v1/chat/completions
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
LLM_TOP_P=1.0
LLM_CONTEXT_LIMIT=32000

# File Upload Configuration
UPLOAD_FOLDER=uploads